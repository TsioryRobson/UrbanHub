# Configuration RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_QUEUE=logs_queue

# Configuration Base de données
DB_PATH=logs.db
DB_TYPE=sqlite

# Configuration API
API_HOST=localhost
API_PORT=8000

# Configuration logging
LOG_LEVEL=INFO
LOG_FORMAT=json
